{
    "width": 1200,
    "height": 5,
    "margin": 5,

    "modules-left": ["custom/power", "hyprland/workspaces"],
    "modules-center": ["clock", "custom/playerctl"],
    "modules-right": ["tray", "network", "battery", "pulseaudio"],

    "custom/playerctl": {
        "exec": "sh -c \"if playerctl status 2>/dev/null | grep -q Playing; then echo 'в™« '$(playerctl metadata --format '{{artist}} - {{title}}'); fi\"",
        "interval": 1,
        "on-click": "playerctl play-pause"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "cursor": true,
    },

    "tray": {
        "icon-size": 20,
        "spacing": 15,
        "cursor": true,
    },

    "bluetooth": {
        "format": " у°‚Ї ",
        "format-disabled": " у°‚І ",
        "format-connected": " у°‚± ",
        "on-click": "blueman-manager",
    },

    "network": {
        "format-wifi": "п‡«  {essid}",
        "format-ethernet": "ој‰  Ethernet",
        "format-linked": "пЃћ  Linked (No IP)",
        "format-disconnected": "пЃ±  Disconnected",
        "tooltip": false,
    },

    "battery": {
        "states": {
            "good": 85,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-plugged": "пѓ§ {capacity}%",
        "format-charging": "пѓ§ {capacity}%",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["п‰„ ", "п‰ѓ ", "п‰‚ ", "п‰Ѓ ", "п‰Ђ "],
        "tooltip-format": "{time}",
        "cursor": false,
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "п‘¦  {volume}%",
        "format-bluetooth": "пЉ” {volume}%",
        "format-bluetooth-muted": "п‘¦  {volume}%",
        "format-icons": {
            "headphone": "пЂҐ ",
            "headset": "пЂҐ ",
            "default": ["пЂЁ "],
        },
        "on-click": "pavucontrol",
    },

    "clock": {
        "format": "{:%a %d/%m/%Y ~ %H:%M}",
        "tooltip-format": "<span size='15000'><tt>{calendar}</tt></span>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#F5C2E7'><b>{}</b></span>",
                "weekdays": "<span color='#89B4FA'><b>{}</b></span>",
                "days": "<span color='#CDD6F4'><b>{}</b></span>",
                "today": "<span color='#F9E2AF'><b>{}</b></span>",
            }
        },
    	"on-click": "swaync-client -t -sw",
    }
}
